    ok.style = 'color:#15803d;font-size:12px;margin-top:8px;text-align:center;padding:8px;background:#dcfce7;border-radius:8px;';
    ok.textContent = '✅ E-mail de redefinição enviado! Verifique sua caixa de entrada.';
    errEl.insertAdjacentElement('afterend', ok);
