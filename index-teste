// Smart mock data with AI categorization
function generateSmartImport(cardId){
  const now=new Date();
  const rawItems=[
    {desc:'Supermercado Extra',type:'expense',amount:312.50},
    {desc:'Posto Shell',type:'expense',amount:180.00},
    {desc:'Netflix',type:'expense',amount:39.90},
    {desc:'Farmácia Drogasil',type:'expense',amount:85.20},
    {desc:'Transferência recebida',type:'income',amount:3500.00},
    {desc:'iFood',type:'expense',amount:67.80},
    {desc:'Uber',type:'expense',amount:32.00},
    {desc:'Academia SmartFit',type:'expense',amount:120.00},
    {desc:'Spotify',type:'expense',amount:21.90},
    {desc:'Claro Internet',type:'expense',amount:109.90},
  ];
  // Deduplicate against existing transactions
  const existingDescs=new Set(state.transactions.map(t=>t.desc.toLowerCase()));
  const unique=rawItems.filter(m=>!existingDescs.has(m.desc.toLowerCase()));
  return unique.map((m,i)=>{
    const catId=smartCategorize(m.desc);
    const d=new Date(now.getFullYear(),now.getMonth(),Math.max(1,now.getDate()-i*2));
    return {id:uid(),desc:m.desc,type:m.type,amount:m.amount,category:catId,date:d.toISOString().split('T')[0],bankId:null,cardId:m.type==='expense'?cardId:null};
  });
}

function confirmImport(){
  if(!importedTxs.length) return;

  // 🔒 BLOQUEIO PRO
  if(!isPro()){
    alert("Importação de fatura é exclusiva do plano PRO.");
    return;
  }

  const cardId = document.getElementById('import-card-select').value;

  // 🚨 VALIDAÇÃO OBRIGATÓRIA
  if(!cardId){
    alert("Selecione um cartão antes de importar.");
    return;
  }

  importedTxs.forEach(t=>{
    // 🔗 VINCULA AO CARTÃO
    t.cardId = cardId;

    // ⭐ EXTRA: MARCA COMO IMPORTADO
    t.source = "imported";

    state.transactions.push(t);

    // 💳 Atualiza limite usado
    if(t.type === 'expense'){
      const c = state.cards.find(c=>c.id === cardId);
      if(c){
        c.used = (c.used || 0) + t.amount;
      }
    }
  });

  save();
  clearImport();

  toast(`${importedTxs.length} transações importadas! 🎉`);
  importedTxs = [];
}

