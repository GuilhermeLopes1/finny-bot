  toast('🗑️ Registro removido.');
}

function confirmDeleteBenefit(id) {
  const b = state.benefits.find(b => b.id === id);
  if (!b) return;
  if (!confirm(`Excluir o benefício "${b.name}"? Todos os registros serão perdidos.`)) return;
  removeBenefit(id);
  renderBenefits();
  toast('🗑️ Benefício removido.');
}

// Helper de data curta
function formatDate(iso) {
  if (!iso) return '';
  const [y,m,d] = iso.split('-');
  return `${d}/${m}`;
}

function addBenefit({ name, emoji, total }) {
  const benefit = {
    id:           'b_' + Date.now(),
    name,
    emoji:        emoji || '💳',
    total:        parseFloat(total) || 0,
    transactions: [],
    createdAt:    new Date().toISOString()
  };
  state.benefits.push(benefit);
  save();
  return benefit;
}

function removeBenefit(id) {
  state.benefits = state.benefits.filter(b => b.id !== id);
  save();
}

function addBenefitTransaction(benefitId, { description, amount, date }) {
  const benefit = state.benefits.find(b => b.id === benefitId);
  if (!benefit) return;
  benefit.transactions.push({
    id:          'bt_' + Date.now(),
    description,
    amount:      parseFloat(amount) || 0,
    date:        date || new Date().toISOString().slice(0, 10)
  });
  save();
}

function removeBenefitTransaction(benefitId, txId) {
  const benefit = state.benefits.find(b => b.id === benefitId);
  if (!benefit) return;
  benefit.transactions = benefit.transactions.filter(t => t.id !== txId);
  save();
}

function editBenefitTransaction(benefitId, txId, { description, amount, date }) {
  const benefit = state.benefits.find(b => b.id === benefitId);
  if (!benefit) return;
  const tx = benefit.transactions.find(t => t.id === txId);
  if (!tx) return;
  if (description !== undefined) tx.description = description;
  if (amount      !== undefined) tx.amount      = parseFloat(amount) || 0;
  if (date        !== undefined) tx.date        = date;
  save();
}

