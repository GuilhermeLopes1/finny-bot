<script>
let editandoId = null;

function abrirEdicao(id, desc, valor, categoria, tipo) {
  editandoId = id;
  document.getElementById("edit-desc").value = desc;
  document.getElementById("edit-valor").value = valor;
  document.getElementById("edit-tipo").value = tipo;

  // Popula categorias dinâmicas do state
  document.getElementById("edit-categoria").innerHTML =
    state.categories.map(c =>
      `<option value="${c.id}">${c.emoji} ${escHtml(c.name)}</option>`
    ).join('');
  document.getElementById("edit-categoria").value = categoria;

  // Usa o sistema de modal do app
  document.getElementById("modal-edicao").classList.add("open");
}

function fecharEdicao() {
  document.getElementById("modal-edicao").classList.remove("open");
  editandoId = null;
}

function salvarEdicao() {
  if (!editandoId) return;
  const t = state.transactions.find(x => x.id === editandoId);
  if (!t) return;

  t.desc = document.getElementById("edit-desc").value.trim();
  t.description = t.desc;
  t.amount = parseFloat(document.getElementById("edit-valor").value);
  t.category = document.getElementById("edit-categoria").value;
  t.type = document.getElementById("edit-tipo").value;

  save();
  fecharEdicao();
  renderTransactions();
  if (state.currentPage === 'dashboard') renderDashboard();
  toast('Transação atualizada! ✅');
}

function toggleTxStatus(id){
  const t=state.transactions.find(x=>x.id===id);
  if(!t)return;
  t.status=(t.status||'paid')==='paid'?'pending':'paid';
  save();
  renderTransactions();
  if(state.currentPage==='dashboard')renderDashboard();
  toast(t.status==='paid'?'Marcado como pago ✅':'Marcado como pendente ⏳');
}
function openAddTransaction(){
  state.editId=null;
  document.getElementById('modal-tx-title').textContent='Nova Transação';
  document.getElementById('tx-desc').value='';
  document.getElementById('tx-amount').value='';
  document.getElementById('tx-date').value=todayISO();
  setTxType('income');
  populateCategorySelect();populateBankSelect();populateCardSelect();
  openModal('modal-transaction');
}
function setTxType(type){
  state.txType=type;
  document.getElementById('type-income').className='type-btn income'+(type==='income'?' active':'');
  document.getElementById('type-expense').className='type-btn expense'+(type==='expense'?' active':'');
  document.getElementById('tx-card-group').style.display=type==='expense'?'':'none';
}
function populateCategorySelect(){
  document.getElementById('tx-category').innerHTML=state.categories.map(c=>`<option value="${c.id}">${c.emoji} ${escHtml(c.name)}</option>`).join('');
}
function populateBankSelect(){
  document.getElementById('tx-bank').innerHTML='<option value="">Nenhuma conta</option>'+state.banks.map(b=>`<option value="${b.id}">${BANK_EMOJIS[b.name]||'🏦'} ${escHtml(b.name)}</option>`).join('');
}
function populateCardSelect(){
  document.getElementById('tx-card').innerHTML='<option value="">Nenhum cartão</option>'+state.cards.map(c=>`<option value="${c.id}">${CARD_BRAND_EMOJIS[c.brand]||'💳'} ${escHtml(c.name)}</option>`).join('');
}
function saveTransaction(){
  const desc=document.getElementById('tx-desc').value.trim();
  const amount=parseFloat(document.getElementById('tx-amount').value);
  const date=document.getElementById('tx-date').value;
  const cat=document.getElementById('tx-category').value;
  const bankId=document.getElementById('tx-bank').value||null;
  const cardId=state.txType==='expense'?(document.getElementById('tx-card').value||null):null;
  if(!desc){toast('Informe a descrição.');return;}
  if(!amount||amount<=0){toast('Informe um valor válido.');return;}
  if(!date){toast('Informe a data.');return;}
  const lim=state.settings.txLimit;
  if(lim>0&&!isPremium()&&state.transactions.length>=lim){openUpgradeModal();toast('Limite atingido. Faça upgrade para Pro!');return;}
  const tx={id:uid(),desc,description:desc,amount,date,type:state.txType,category:cat,bankId,cardId,status:'paid'};
  state.transactions.push(tx);
  if(cardId&&state.txType==='expense'){const c=state.cards.find(c=>c.id===cardId);if(c)c.used=(c.used||0)+amount;}
  save();closeModal('modal-transaction');toast('Transação adicionada! ✅');
  if(state.currentPage==='transactions')renderTransactions();
  if(state.currentPage==='dashboard')renderDashboard();
}
function deleteTransaction(id){
  const t=state.transactions.find(x=>x.id===id);
  if(t&&t.cardId&&t.type==='expense'){const c=state.cards.find(x=>x.id===t.cardId);if(c)c.used=Math.max(0,(c.used||0)-t.amount);}
  state.transactions=state.transactions.filter(t=>t.id!==id);
  save();renderTransactions();toast('Transação excluída.');
}

