// Mapa de cores automáticas por emoji/tipo
const BENEFIT_COLORS = {
  '🍽️': '#f97316', '🛒': '#22c55e', '⛽': '#3b82f6',
  '🏥': '#ef4444', '🎓': '#8b5cf6', '💳': '#6C63FF',
  '🎁': '#ec4899', '🚗': '#14b8a6'
};

function renderBenefits() {
  const grid    = document.getElementById('benefits-grid');
  const empty   = document.getElementById('benefits-empty');
  const summary = document.getElementById('benefits-summary');
  if (!grid) return;

  const benefits = state.benefits || [];

  // ── Empty state ──
  grid.classList.toggle('hidden', benefits.length === 0);
  empty.classList.toggle('hidden', benefits.length > 0);

  // ── Resumo geral ──
  const totalDisp  = benefits.reduce((s, b) => s + (b.total || 0), 0);
  const totalUsado = benefits.reduce((s, b) => s + benefitCalc(b).used, 0);
  const totalRest  = totalDisp - totalUsado;

  summary.innerHTML = benefits.length ? `
    <div class="benefit-summary-card">
      <div class="summary-icon">💰</div>
      <div class="summary-label">Total Disponível</div>
      <div class="summary-value">R$ ${fmt(totalDisp)}</div>
    </div>
    <div class="benefit-summary-card">
      <div class="summary-icon">📤</div>
      <div class="summary-label">Total Utilizado</div>
      <div class="summary-value" style="color:var(--danger)">R$ ${fmt(totalUsado)}</div>
    </div>
    <div class="benefit-summary-card">
      <div class="summary-icon">✅</div>
      <div class="summary-label">Saldo Restante</div>
      <div class="summary-value" style="color:var(--success)">R$ ${fmt(totalRest)}</div>
    </div>
  ` : '';

  // ── Cards ──
  grid.innerHTML = benefits.map(b => {
    const { used, remaining, pct } = benefitCalc(b);
    const status   = benefitStatus(pct);
    const forecast = benefitForecast(b);
    const color    = BENEFIT_COLORS[b.emoji] || 'var(--primary)';
    const bgLight  = color + '18';

    // Alerta inteligente
    let alertClass = 'green', alertIcon = '💡', alertMsg = '';
    if (pct >= 85) {
      alertClass = 'red'; alertIcon = '🚨';
      alertMsg = `Atenção! Você já usou <strong>${pct}%</strong> deste benefício.`;
    } else if (pct >= 60) {
      alertClass = 'yellow'; alertIcon = '⚠️';
      alertMsg = `Uso moderado. Você usou <strong>${pct}%</strong> — monitore os próximos gastos.`;
    } else if (pct > 0) {
      alertMsg = `Ótimo controle! Você usou <strong>${pct}%</strong> — restam R$ ${fmt(remaining)}.`;
    }

    // Previsão
    let forecastHtml = '';
    if (forecast && forecast.dailyRate > 0) {
      if (forecast.daysUntilEmpty !== null && forecast.daysUntilEmpty < forecast.daysRemaining) {
        forecastHtml = `<div class="benefit-alert red" style="margin-top:8px">
          ⏳ No ritmo atual, o saldo acaba em <strong>${forecast.daysUntilEmpty} dias</strong>.
        </div>`;
      } else {
        forecastHtml = `<div class="benefit-alert green" style="margin-top:8px">
          📅 No ritmo atual, o saldo <strong>dura até o fim do mês</strong>.
        </div>`;
      }
    }

    // Transações recentes (últimas 3)
    const txs = [...(b.transactions || [])].sort((a,z) => z.date.localeCompare(a.date));
    const recentTxs = txs.slice(0, 3);
    const txHtml = recentTxs.map(t => `
      <div class="benefit-tx-item">
        <span class="benefit-tx-desc">${t.description}</span>
        <span class="benefit-tx-date">${formatDate(t.date)}</span>
        <span class="benefit-tx-amount">- R$ ${fmt(t.amount)}</span>
        <div class="benefit-tx-actions">
          <button title="Editar" onclick="openBenefitTxModal('${b.id}','${t.id}')">✏️</button>
          <button title="Excluir" onclick="deleteBenefitTx('${b.id}','${t.id}')">🗑️</button>
        </div>
      </div>
    `).join('');

    const moreTxs = txs.length > 3
      ? `<p style="font-size:11px;color:var(--muted);text-align:center;margin-top:4px">+${txs.length - 3} transações anteriores</p>`
      : '';

    return `
      <div class="benefit-card" style="--benefit-color:${color};--benefit-bg:${bgLight}">
        <div class="benefit-card-header">
          <div class="benefit-card-identity">
            <div class="benefit-icon">${b.emoji}</div>
            <div>
              <div class="benefit-name">${b.name}</div>
              <div class="benefit-total-label">Saldo total: R$ ${fmt(b.total)}</div>
            </div>
          </div>
          <span class="benefit-status-badge ${pct>=85?'danger':pct>=60?'warning':''}">
            ${status.emoji} ${status.label}
          </span>
        </div>

        <div class="benefit-amounts">
          <div class="benefit-amount-block">
            <div class="amount-label">Utilizado</div>
            <div class="amount-value used">R$ ${fmt(used)}</div>
          </div>
          <div class="benefit-amount-block">
            <div class="amount-label">Restante</div>
            <div class="amount-value remain">R$ ${fmt(remaining)}</div>
          </div>
        </div>

        <div class="benefit-progress-wrap">
          <div class="benefit-progress-header">
            <span>Progresso de uso</span>
            <strong>${pct}% usado</strong>
          </div>
          <div class="benefit-progress-bar">
            <div class="benefit-progress-fill" style="width:${pct}%;background:${color}"></div>
          </div>
        </div>

        ${alertMsg ? `<div class="benefit-alert ${alertClass}"><span class="benefit-alert-icon">${alertIcon}</span><span>${alertMsg}</span></div>` : ''}
        ${forecastHtml}

        ${txs.length ? `
          <div class="benefit-tx-list open">
            ${txHtml}
            ${moreTxs}
          </div>
        ` : ''}

        <div class="benefit-card-actions">
          <button class="btn btn-outline btn-sm" onclick="openBenefitTxModal('${b.id}')">➕ Registrar uso</button>
          <button class="btn btn-outline btn-sm" onclick="openBenefitModal('${b.id}')">✏️ Editar</button>
          <button class="btn btn-danger btn-sm" onclick="confirmDeleteBenefit('${b.id}')">🗑️</button>
        </div>
      </div>
    `;
  }).join('');
}

function deleteBenefitTx(benefitId, txId) {
