/* ═══════════════════════════════════════════════════
   BENEFITS — Estilos premium estilo fintech
═══════════════════════════════════════════════════ */

/* Grid de cards de benefícios */
.benefits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 18px;
  margin-bottom: 24px;
}

/* Card individual de benefício */
.benefit-card {
  background: var(--card);
  border-radius: 20px;
  padding: 22px;
  border: 1.5px solid var(--border);
  box-shadow: 0 2px 16px rgba(0,0,0,.06);
  transition: transform .2s, box-shadow .2s;
  position: relative;
  overflow: hidden;
}
.benefit-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 28px rgba(0,0,0,.1);
}

/* Faixa decorativa no topo do card */
.benefit-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4px;
  background: var(--benefit-color, var(--primary));
  border-radius: 20px 20px 0 0;
}

/* Cabeçalho do card */
.benefit-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16px;
}
.benefit-card-identity {
  display: flex;
  align-items: center;
  gap: 12px;
}
.benefit-icon {
  width: 44px; height: 44px;
  border-radius: 14px;
  background: var(--benefit-bg, var(--primary-light));
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
  flex-shrink: 0;
}
.benefit-name {
  font-size: 15px;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -.2px;
}
.benefit-total-label {
  font-size: 11px;
  color: var(--muted);
  margin-top: 2px;
  font-weight: 500;
}

/* Badge de status */
.benefit-status-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 700;
  background: #f0fdf4;
  color: #16a34a;
  flex-shrink: 0;
}
.benefit-status-badge.warning {
  background: #fffbeb;
  color: #d97706;
}
.benefit-status-badge.danger {
  background: #fef2f2;
  color: #dc2626;
}

/* Valores principais */
.benefit-amounts {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 16px;
}
.benefit-amount-block {
  background: var(--bg);
  border-radius: 12px;
  padding: 10px 14px;
}
.benefit-amount-block .amount-label {
  font-size: 10px;
  font-weight: 700;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .04em;
  margin-bottom: 4px;
}
.benefit-amount-block .amount-value {
  font-size: 16px;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -.3px;
}
.benefit-amount-block .amount-value.used   { color: var(--danger); }
.benefit-amount-block .amount-value.remain { color: var(--success); }

/* Barra de progresso */
.benefit-progress-wrap {
  margin-bottom: 10px;
}
.benefit-progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}
.benefit-progress-header span {
  font-size: 12px;
  font-weight: 700;
  color: var(--muted);
}
.benefit-progress-header strong {
  font-size: 13px;
  font-weight: 800;
  color: var(--text);
}
.benefit-progress-bar {
  height: 8px;
  background: var(--border);
  border-radius: 99px;
  overflow: hidden;
}
.benefit-progress-fill {
  height: 100%;
  border-radius: 99px;
  transition: width .5s cubic-bezier(.4,0,.2,1);
  background: var(--benefit-color, var(--primary));
}

/* Alerta inteligente */
.benefit-alert {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 9px 12px;
  border-radius: 10px;
  font-size: 12px;
  font-weight: 600;
  margin-bottom: 14px;
  line-height: 1.4;
}
.benefit-alert.green  { background: #f0fdf4; color: #15803d; }
.benefit-alert.yellow { background: #fffbeb; color: #b45309; }
.benefit-alert.red    { background: #fef2f2; color: #b91c1c; }
.benefit-alert-icon   { font-size: 16px; flex-shrink: 0; }

/* Ações do card */
.benefit-card-actions {
  display: flex;
  gap: 8px;
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid var(--border);
}
.benefit-card-actions .btn {
  flex: 1;
  font-size: 12px;
  padding: 8px 12px;
  border-radius: 10px;
}

/* Lista de transações dentro do card */
.benefit-tx-list {
  margin-top: 14px;
  display: none; /* toggle via JS */
}
.benefit-tx-list.open { display: block; }

.benefit-tx-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 9px 12px;
  border-radius: 10px;
  background: var(--bg);
  margin-bottom: 6px;
  font-size: 13px;
  transition: background .15s;
}
.benefit-tx-item:hover { background: var(--primary-light); }
.benefit-tx-desc {
  font-weight: 600;
  color: var(--text);
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.benefit-tx-date {
  font-size: 11px;
  color: var(--muted);
  margin-left: 8px;
  flex-shrink: 0;
}
.benefit-tx-amount {
  font-weight: 800;
  color: var(--danger);
  margin-left: 12px;
  flex-shrink: 0;
}
.benefit-tx-actions {
  display: flex;
  gap: 4px;
  margin-left: 8px;
}
.benefit-tx-actions button {
  background: none;
  border: none;
  cursor: pointer;
  padding: 3px 5px;
  border-radius: 6px;
  font-size: 13px;
  color: var(--muted);
  transition: all .15s;
}
.benefit-tx-actions button:hover { background: var(--border); color: var(--text); }

/* Dashboard de benefícios — resumo no topo da página */
.benefits-summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
  margin-bottom: 24px;
}
.benefit-summary-card {
  background: var(--card);
  border-radius: 16px;
  padding: 18px 20px;
  border: 1.5px solid var(--border);
  text-align: center;
}
.benefit-summary-card .summary-icon { font-size: 26px; margin-bottom: 6px; }
.benefit-summary-card .summary-label {
  font-size: 11px;
  font-weight: 700;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .04em;
  margin-bottom: 4px;
}
.benefit-summary-card .summary-value {
  font-size: 20px;
  font-weight: 900;
  color: var(--text);
  letter-spacing: -.4px;
}

/* Dark mode — ajustes de benefícios */
body.dark-mode .benefit-card            { background: #1a1a2e !important; border-color: #2a2a45 !important; }
body.dark-mode .benefit-amount-block    { background: #12121f !important; }
body.dark-mode .benefit-tx-item         { background: #12121f !important; }
