function benefitCalc(benefit) {
  const used = (benefit.transactions || []).reduce((s, t) => s + t.amount, 0);
  const total = benefit.total || 0;
  const remaining = Math.max(0, total - used);
  const pct = total > 0 ? Math.min(100, Math.round((used / total) * 100)) : 0;
  return { used, remaining, pct };
}

function benefitStatus(pct) {
  if (pct >= 85) return { color: '#ef4444', label: 'Crítico',  emoji: '🔴' };
  if (pct >= 60) return { color: '#f59e0b', label: 'Atenção',  emoji: '🟡' };
  return              { color: '#22c55e', label: 'Saudável', emoji: '🟢' };
}

function benefitForecast(benefit) {
  const txs = benefit.transactions || [];
  if (!txs.length) return null;

  const now = new Date();
  const firstDay = new Date(now.getFullYear(), now.getMonth(), 1);
  const lastDay  = new Date(now.getFullYear(), now.getMonth() + 1, 0);
  const daysInMonth   = lastDay.getDate();
  const daysPassed    = now.getDate();
  const daysRemaining = daysInMonth - daysPassed;

  // Filtra transações do mês atual
  const monthTxs = txs.filter(t => {
    const d = new Date(t.date);
    return d >= firstDay && d <= lastDay;
  });

  if (!monthTxs.length) return null;

  const usedThisMonth = monthTxs.reduce((s, t) => s + t.amount, 0);
  const dailyRate     = daysPassed > 0 ? usedThisMonth / daysPassed : 0;
  const projectedTotal = dailyRate * daysInMonth;
  const { remaining } = benefitCalc(benefit);

  const daysUntilEmpty = dailyRate > 0
    ? Math.floor(remaining / dailyRate)
    : null;

  return {
    dailyRate,
    projectedTotal,
    daysUntilEmpty,
    daysRemaining,
    usedThisMonth
  };
}

