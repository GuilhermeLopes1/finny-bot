async function saveDebt() {
  const name = document.getElementById('debt-name').value.trim();
  const total = parseFloat(document.getElementById('debt-total').value) || 0;
  const paid = parseFloat(document.getElementById('debt-paid').value) || 0;
  const installment = parseFloat(document.getElementById('debt-installment').value) || 0;
  const installmentsTotal = parseInt(document.getElementById('debt-installments-total').value) || null;
  const startDate = document.getElementById('debt-start-date').value || null;
  const dueDay = parseInt(document.getElementById('debt-due-day').value) || null;
  const icon = document.getElementById('debt-icon').value;

  if (!name) { toast('❌ Informe o nome da dívida'); return; }
  if (total <= 0) { toast('❌ Informe o valor total'); return; }
  if (installment <= 0) { toast('❌ Informe o valor da parcela'); return; }

  if (state.editId) {
    const idx = state.debts.findIndex(d => d.id === state.editId);
    if (idx > -1) {
                  state.debts[idx] = { ...state.debts[idx], name, icon, total, paid, installment, installmentsTotal, startDate, dueDay };
    }
  } else {
    state.debts.push({
      id: 'debt_' + Date.now(),
      name, icon, total, paid, installment, installmentsTotal, startDate, dueDay,
      createdAt: new Date().toISOString()
    });
  }

closeModal('modal-debt');
  state.editId = null;
  await save();
  renderDebts();
