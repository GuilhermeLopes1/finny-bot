// ── Contador animado para valores financeiros ──────────────
function animateCounter(el, targetValue, prefix='R$ ', duration=800) {
  const start = performance.now();
  const startVal = 0;
  const isNegative = targetValue < 0;
  const absTarget = Math.abs(targetValue);

  function update(now) {
    const elapsed = now - start;
    const progress = Math.min(elapsed / duration, 1);
    // Ease out cubic
    const ease = 1 - Math.pow(1 - progress, 3);
    const current = startVal + (absTarget - startVal) * ease;
    el.textContent = (isNegative ? '-' : '') + prefix +
      current.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    if (progress < 1) requestAnimationFrame(update);
  }
  requestAnimationFrame(update);
}

