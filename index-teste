function setPayType(type){
  payType = type;

  document.getElementById('pay-full-btn').className =
    'type-btn expense' + (type === 'full' ? ' active' : '');

  document.getElementById('pay-partial-btn').className =
    'type-btn income' + (type === 'partial' ? ' active' : '');

  document.getElementById('pay-partial-group')
    .classList.toggle('hidden', type !== 'partial');
}

function confirmPayInvoice(){
  const c = state.cards.find(x => x.id === payingCardId);
  if(!c) return;

  const bankId = document.getElementById('pay-invoice-bank').value;
  if(!bankId){
    toast('Selecione a conta bancária para débito.');
    return;
  }

  const bank = state.banks.find(b => b.id === bankId);
  if(!bank) return;

  const totalInvoice = c.currentInvoice || 0;
  let payAmt = 0;

  // 🔥 PAGAMENTO TOTAL
  if(payType === 'full'){
    payAmt = totalInvoice;

    c.used = Math.max(0, (c.used || 0) - payAmt);
    c.currentInvoice = 0;

    // marcar como pagas
    state.transactions
      .filter(t => t.cardId === payingCardId)
      .forEach(t => t.status = 'paid');
  }

  // 🔥 PAGAMENTO PARCIAL
  else {
    payAmt = parseFloat(document.getElementById('pay-partial-amount').value) || 0;

    if(!payAmt || payAmt <= 0){
      toast('Informe o valor do pagamento parcial.');
      return;
    }

    if(payAmt > totalInvoice){
      toast(`Valor maior que a fatura (${fmtBRL(totalInvoice)}).`);
      return;
    }

    c.currentInvoice = Math.max(0, totalInvoice - payAmt);
    c.used = Math.max(0, (c.used || 0) - payAmt);
  }

  if(payAmt <= 0){
    closeModal('modal-pay-invoice');
    return;
  }

  // 💰 desconta do banco
  bank.balance = Math.max(0, (bank.balance || 0) - payAmt);

  // 🧾 registra transação
  const payTx = {
    id: uid(),
    desc: `Pagamento Fatura – ${c.name}`,
    amount: payAmt,
    date: todayISO(),
    type: 'expense',
    category: state.categories[0]?.id || '',
    bankId,
    cardId: null,
    status: 'paid'
  };

  state.transactions.push(payTx);

  save();
  closeModal('modal-pay-invoice');
  renderCards();

  toast(`Fatura paga: ${fmtBRL(payAmt)} debitado de ${bank.name} ✅`);

  if(state.currentPage === 'dashboard'){
    renderDashboard();
  }
}

