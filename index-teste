<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<link rel="shortcut icon" href="favicon.png" type="image/x-icon">
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Allo Finanças</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>

.phone-box {
  display: flex;
  gap: 8px;
  margin: 10px 0;
}

.phone-box input {
  flex: 1;
  padding: 10px;
  border-radius: 8px;
  border: 1px solid #ccc;
  font-size: 14px;
}

.phone-box input:focus {
  border-color: #4CAF50;
  outline: none;
}

.phone-box button {
  padding: 10px 16px;
  border: none;
  border-radius: 8px;
  background: #4CAF50;
  color: white;
  font-weight: bold;
  cursor: pointer;
  transition: 0.2s;
}

.phone-box button:hover {
  background: #43a047;
}


:root{
  --primary:#6C63FF;
  --primary-dark:#5a52d5;
  --primary-light:#ede9ff;
  --success:#22c55e;
  --danger:#ef4444;
  --warning:#f59e0b;
  --bg:#F0F2F8;          /* ← levemente mais azulado, menos branco cru */
  --card:#ffffff;
  --text:#0F0F23;         /* ← mais escuro, mais legível */
  --muted:#8892A4;        /* ← muted mais refinado */
  --border:#E8EBF2;       /* ← borda mais sutil */
  --sidebar-w:250px;
  --radius:18px;
}

/* === MODO ESCURO === */
/* === MODO ESCURO === */
body.dark-mode {
  --bg: #0f0f1a;
  --card: #1a1a2e;
  --text: #e8eaf0;
  --muted: #7a85a0;
  --border: #2a2a45;
  --primary-light: #2a2655;
}
body.dark-mode .sidebar               { background: #12121f !important; }
body.dark-mode .topbar                { background: #0f0f1a !important; }
body.dark-mode .card                  { background: #1a1a2e !important; }
body.dark-mode .stat-card             { background: #1a1a2e !important; }
body.dark-mode .modal                 { background: #1a1a2e !important; }
body.dark-mode .auth-card             { background: #1a1a2e !important; }
body.dark-mode .tx-row                { background: #1a1a2e !important; }
body.dark-mode .tx-row:hover          { background: #222240 !important; }
body.dark-mode tr:hover td            { background: #222240 !important; }
body.dark-mode th                     { background: #12121f !important; }
body.dark-mode td                     { background: transparent !important; }
body.dark-mode .sidebar-profile       { background: #12121f !important; }
body.dark-mode .form-group input,
body.dark-mode .form-group select,
body.dark-mode .form-group textarea   { background: #0f0f1a !important; color: #e8eaf0 !important; border-color: #2a2a45 !important; }
body.dark-mode .category-card         { background: #1a1a2e !important; }
body.dark-mode .import-row            { background: #12121f !important; }
body.dark-mode .tx-filter-pill        { background: #1a1a2e !important; border-color: #2a2a45 !important; color: #7a85a0 !important; }
body.dark-mode .tx-filter-pill.active { background: var(--primary) !important; color: #fff !important; }
body.dark-mode .badge-income          { background: #14532d !important; color: #86efac !important; }
body.dark-mode .badge-expense         { background: #7f1d1d !important; color: #fca5a5 !important; }
body.dark-mode .badge-paid            { background: #14532d !important; color: #86efac !important; }
body.dark-mode .badge-pending         { background: #713f12 !important; color: #fde68a !important; }
body.dark-mode .plan-pill.free        { background: #2a2a45 !important; }
body.dark-mode #dashboard-greeting    { background: #1a1a2e !important; }
body.dark-mode .empty-state { background: #12121f !important; border-color: #2a2a45 !important; }

*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
#auth-screen{display:flex;align-items:center;justify-content:center;min-height:100vh;background:linear-gradient(135deg,var(--primary) 0%,#a855f7 100%);}
.auth-card{background:var(--card);border-radius:20px;padding:36px 32px;width:100%;max-width:420px;box-shadow:0 20px 60px rgba(0,0,0,.2);}
.auth-logo{text-align:center;margin-bottom:24px;}
.auth-logo h1{font-size:26px;font-weight:800;color:var(--primary);}
.auth-logo p{color:var(--muted);font-size:13px;margin-top:3px;}
.auth-tabs{display:flex;background:var(--bg);border-radius:12px;padding:4px;margin-bottom:20px;}
.auth-tab{flex:1;padding:9px;text-align:center;border-radius:9px;cursor:pointer;font-size:13px;font-weight:600;color:var(--muted);transition:.15s;}
.auth-tab.active{background:var(--card);color:var(--primary);box-shadow:0 1px 4px rgba(0,0,0,.08);}
.auth-panel{display:none;}
.auth-panel.active{display:block;}
.form-group{margin-bottom:14px;}
.form-group label{display:block;font-size:12px;font-weight:700;margin-bottom:5px;color:var(--text);text-transform:uppercase;letter-spacing:.03em;}
.form-group input,.form-group select,.form-group textarea{width:100%;padding:10px 13px;border:1.5px solid var(--border);border-radius:10px;font-size:14px;color:var(--text);background:var(--bg);transition:border .2s;font-family:inherit;}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{outline:none;border-color:var(--primary);background:var(--card);}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:11px 20px;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;font-family:inherit;text-decoration:none;}
.btn-primary{background:var(--primary);color:#fff;}
.btn-primary:hover{background:var(--primary-dark);transform:translateY(-1px);}
.btn-block{width:100%;}
.btn-sm{padding:7px 14px;font-size:13px;border-radius:8px;}
.btn-xs{padding:5px 10px;font-size:12px;border-radius:7px;}
.btn-outline{background:transparent;border:1.5px solid var(--border);color:var(--text);}
.btn-outline:hover{border-color:var(--primary);color:var(--primary);}
.btn-danger{background:var(--danger);color:#fff;}
.btn-danger:hover{background:#dc2626;}
.btn-success{background:var(--success);color:#fff;}
.btn-google{background:#fff;color:#3c4043;border:1.5px solid var(--border);margin-top:10px;}
.btn-google:hover{background:#f8f9fa;border-color:#ddd;}
.btn-pro{background:linear-gradient(135deg,#f59e0b,#ef4444);color:#fff;}
.btn-pro:hover{opacity:.9;transform:translateY(-1px);}
.auth-divider{display:flex;align-items:center;gap:10px;margin:14px 0;color:var(--muted);font-size:13px;}
.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:var(--border);}
.auth-error{color:var(--danger);font-size:12px;margin-top:8px;text-align:center;display:none;padding:8px;background:#fee2e2;border-radius:8px;}
.auth-success{color:#15803d;font-size:12px;margin-top:8px;text-align:center;display:none;padding:8px;background:#dcfce7;border-radius:8px;}
#app{display:none;min-height:100vh;}
.sidebar{
  position:fixed;top:0;left:0;width:var(--sidebar-w);height:100vh;
  background:var(--card);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;z-index:100;overflow-y:auto;
  box-shadow:2px 0 12px rgba(0,0,0,.04);
}
.sidebar-header{
  padding:22px 18px 16px;
  border-bottom:1px solid var(--border);
}
.sidebar-header h2{
  font-size:20px;
  font-weight:900;
  color:var(--primary);
  letter-spacing:-.3px;
}
.plan-pill{display:inline-block;padding:2px 9px;border-radius:20px;font-size:10px;font-weight:700;margin-top:4px;}
.plan-pill.free{background:#e5e7eb;color:var(--muted);}
.plan-pill.pro{background:linear-gradient(135deg,#f59e0b,#ef4444);color:#fff;}
.plan-pill.admin{background:var(--primary-light);color:var(--primary);}
.nav{flex:1;padding:10px 0;}
.nav-section{padding:6px 18px 2px;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-top:6px;}
.sidebar{
  position:fixed;top:0;left:0;width:var(--sidebar-w);height:100vh;
  background:var(--card);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;z-index:100;overflow-y:auto;
  box-shadow:2px 0 12px rgba(0,0,0,.04);
}
.sidebar-header{
  padding:22px 18px 16px;
  border-bottom:1px solid var(--border);
}
.sidebar-header h2{
  font-size:20px;
  font-weight:900;
  color:var(--primary);
  letter-spacing:-.3px;
}
.nav-item{
  display:flex;align-items:center;gap:10px;
  padding:10px 14px;
  margin:1px 8px;
  cursor:pointer;
  color:var(--muted);
  font-size:13px;font-weight:500;
  transition:all .18s;
  border-left:none;
  border-radius:10px;
}
.nav-item:hover{
  background:var(--primary-light);
  color:var(--primary);
  padding-left:18px;
}
.nav-item.active{
  background:var(--primary-light);
  color:var(--primary);
  font-weight:700;
  box-shadow:inset 3px 0 0 var(--primary);
}
.nav-item .nav-icon{font-size:15px;width:22px;text-align:center;}
.nav-item .nav-icon{font-size:16px;width:22px;text-align:center;}
.nav-item .pro-tag{font-size:9px;font-weight:700;background:linear-gradient(135deg,#f59e0b,#ef4444);color:#fff;padding:1px 6px;border-radius:20px;margin-left:auto;}
/* NOVO */
.sidebar-footer{
  padding:0;
  border-top:1px solid var(--border);
  flex-shrink:0;
}
/* Card de perfil no rodapé */
.sidebar-profile{
  display:flex;align-items:center;gap:10px;
  padding:14px 16px;
  margin:8px;
  border-radius:14px;
  background:var(--bg);
  cursor:pointer;
  transition:background .15s;
  position:relative;
}
.sidebar-profile:hover{background:var(--primary-light);}

.avatar{
  width:38px;height:38px;border-radius:12px;
  background:linear-gradient(135deg,var(--primary),#A855F7);
  color:#fff;
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:15px;
  flex-shrink:0;
  box-shadow:0 3px 10px rgba(108,99,255,.3);
  letter-spacing:-.5px;
}
.sidebar-footer .user-info{flex:1;min-width:0;}
.sidebar-footer .user-name{
  font-size:13px;font-weight:700;
  color:var(--text);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
.sidebar-footer .user-email{
  font-size:10px;color:var(--muted);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
  margin-top:1px;
}
.logout-btn{
  background:none;border:none;cursor:pointer;
  color:var(--muted);font-size:16px;padding:5px;
  border-radius:8px;flex-shrink:0;
  transition:all .15s;
}
.logout-btn:hover{background:#fee2e2;color:var(--danger);}
.main{margin-left:var(--sidebar-w);min-height:100vh;}
.topbar{
  position:sticky;top:0;
  background:var(--bg);
  backdrop-filter:blur(12px);
  -webkit-backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
  padding:14px 32px;
  display:flex;align-items:center;justify-content:space-between;
  z-index:50;
}
.topbar h1{
  font-size:22px;
  font-weight:800;
  letter-spacing:-.3px;
  color:var(--text);
}
.content{padding:28px 32px;}
.card{
  background:var(--card);
  border-radius:20px;
  padding:22px 24px;
  border:none;
  box-shadow:0 2px 16px rgba(0,0,0,.06), 0 1px 4px rgba(0,0,0,.03);
  transition:box-shadow .2s;
}
.card:hover{
  box-shadow:0 6px 24px rgba(0,0,0,.09);
}
.card-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:20px;
  padding-bottom:14px;
  border-bottom:1px solid var(--border);
}
.card-title{
  font-size:14px;
  font-weight:800;
  color:var(--text);
  display:flex;align-items:center;gap:7px;
}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px;}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:22px;}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
/* ===== STAT CARDS MODERNOS (estilo fintech) ===== */
.stat-card{
  background:var(--card);
  border-radius:18px;
  padding:20px 22px;
  border:none;
  position:relative;
  overflow:hidden;
  box-shadow:0 2px 12px rgba(0,0,0,.06), 0 1px 3px rgba(0,0,0,.04);
  transition:transform .2s, box-shadow .2s;
}
.stat-card:hover{
  transform:translateY(-3px);
  box-shadow:0 8px 24px rgba(0,0,0,.10);
}
/* Bolinha decorativa maior e mais suave */
.stat-card::before{
  content:'';position:absolute;right:-12px;top:-12px;
  width:72px;height:72px;border-radius:50%;opacity:.06;
  pointer-events:none;
}
.stat-card.green::before{background:var(--success);}
.stat-card.red::before{background:var(--danger);}
.stat-card.orange::before{background:var(--warning);}
.stat-card.blue::before{background:var(--primary);}

/* Rótulo do card */
.stat-label{
  font-size:11px;
  color:var(--muted);
  font-weight:700;
  margin-bottom:8px;
  display:flex;align-items:center;gap:6px;
  text-transform:uppercase;
  letter-spacing:.04em;
}
/* Valor principal — mais destaque */
.stat-value{
  font-size:26px;
  font-weight:800;
  letter-spacing:-.5px;
  line-height:1.1;
}
.stat-value.green{color:var(--success);}
.stat-value.red{color:var(--danger);}
.stat-value.orange{color:var(--warning);}
.stat-value.blue{color:var(--primary);}

/* Ocultar valores */
body.hide-values .stat-value,
body.hide-values .tx-amount,
body.hide-values .amount-pos,
body.hide-values .amount-neg,
body.hide-values #greeting-balance {
  filter: blur(6px);
  user-select: none;
  pointer-events: none;
  transition: filter 0.3s;
}

.stat-change{font-size:11px;margin-top:6px;font-weight:600;}


.stat-change.up{color:var(--success);}
.stat-change.down{color:var(--danger);}
.stat-change.neutral{color:var(--muted);}
.table-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:13px;}
th{
  padding:10px 14px;
  text-align:left;
  font-size:10px;
  font-weight:800;
  color:var(--muted);
  text-transform:uppercase;
  letter-spacing:.06em;
  border-bottom:2px solid var(--border);
  background:var(--bg);
}
th:first-child{border-radius:10px 0 0 0;}
th:last-child{border-radius:0 10px 0 0;}
td{
  padding:13px 14px;
  border-bottom:1px solid var(--border);
  vertical-align:middle;
}
tr:last-child td{border-bottom:none;}
tr{transition:background .15s;}
tr:hover td{background:#F5F6FC;}
.badge{
  display:inline-flex;
  align-items:center;
  gap:4px;
  padding:4px 10px;
  border-radius:20px;
  font-size:10px;
  font-weight:700;
  text-transform:uppercase;
  letter-spacing:.03em;
}
.badge-income{background:#dcfce7;color:#15803d;}
.badge-expense{background:#fee2e2;color:#b91c1c;}
.badge-paid{background:#dcfce7;color:#15803d;}
.badge-pending{background:#fef9c3;color:#854d0e;}
/* Subscription page */
.sub-plan-card{background:var(--card);border:2px solid var(--border);border-radius:16px;padding:24px;text-align:center;transition:border-color .2s;}
.sub-plan-card.current-plan{border-color:var(--primary);}
.sub-plan-card.featured{position:relative;}
.sub-plan-price{font-size:32px;font-weight:800;margin:10px 0 4px;}
.sub-plan-period{font-size:12px;color:var(--muted);margin-bottom:16px;}
.sub-plan-name{font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:6px;}
.sub-feature-list{text-align:left;font-size:13px;margin-bottom:18px;}
.sub-feature-list li{padding:5px 0;list-style:none;display:flex;align-items:center;gap:7px;border-bottom:1px solid var(--border);}
.sub-feature-list li:last-child{border-bottom:none;}
/* NOVO */
.amount-pos{color:var(--success);font-weight:800;}
.amount-neg{color:var(--danger);font-weight:800;}

/* ===== FEED DE TRANSAÇÕES ===== */
.tx-feed{display:flex;flex-direction:column;gap:0;}

.tx-group-label{
  font-size:11px;font-weight:800;
  color:var(--muted);text-transform:uppercase;
  letter-spacing:.06em;
  padding:14px 0 6px;
}

.tx-row{
  display:flex;align-items:center;gap:14px;
  padding:14px 18px;
  background:var(--card);
  border-bottom:1px solid var(--border);
  transition:background .15s;
  cursor:default;
}
.tx-row:first-of-type{border-radius:16px 16px 0 0;}
.tx-row:last-of-type{border-bottom:none;border-radius:0 0 16px 16px;}
.tx-row:only-of-type{border-radius:16px;}
.tx-row:hover{background:#F5F6FC;}

/* Ícone da categoria */
.tx-icon{
  width:42px;height:42px;flex-shrink:0;
  border-radius:13px;
  display:flex;align-items:center;justify-content:center;
  font-size:19px;
}

/* Coluna central */
.tx-info{flex:1;min-width:0;}
.tx-desc{
  font-size:13px;font-weight:700;
  color:var(--text);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
.tx-meta{
  font-size:11px;color:var(--muted);
  font-weight:500;margin-top:2px;
  display:flex;align-items:center;gap:6px;
}

/* Coluna da direita */
.tx-right{
  display:flex;flex-direction:column;
  align-items:flex-end;gap:5px;flex-shrink:0;
}
.tx-amount{font-size:14px;font-weight:800;letter-spacing:-.2px;}
.tx-amount.pos{color:var(--success);}
.tx-amount.neg{color:var(--danger);}

.tx-actions{display:flex;gap:3px;opacity:0;transition:opacity .15s;}
.tx-row:hover .tx-actions{opacity:1;}
.tx-actions .icon-btn{
  padding:3px 6px;font-size:12px;
  background:var(--bg);border-radius:7px;
}

/* Barra de filtros */
.tx-filter-bar{
  display:flex;align-items:center;gap:8px;
  flex-wrap:wrap;
  margin-bottom:16px;
}
.tx-filter-pill{
  padding:6px 14px;border:1.5px solid var(--border);
  border-radius:20px;background:var(--card);
  cursor:pointer;font-size:12px;font-weight:700;
  color:var(--muted);transition:all .15s;
  font-family:inherit;
}
.tx-filter-pill.active{
  background:var(--primary);border-color:var(--primary);
  color:#fff;box-shadow:0 2px 8px rgba(108,99,255,.3);
}
.tx-filter-pill:hover:not(.active){
  border-color:var(--primary);color:var(--primary);
}
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;align-items:center;justify-content:center;padding:16px;}
.modal-overlay.open{display:flex;}
.modal{background:var(--card);border-radius:18px;padding:26px 26px 22px;width:100%;max-width:480px;max-height:90vh;overflow-y:auto;box-shadow:0 24px 80px rgba(0,0,0,.22);}
.modal-wide{max-width:620px;}
.modal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;}
.modal-header h3{font-size:17px;font-weight:700;}
.modal-close{background:none;border:none;font-size:22px;cursor:pointer;color:var(--muted);line-height:1;}
.modal-close:hover{color:var(--text);}
.modal-footer{display:flex;gap:10px;justify-content:flex-end;margin-top:18px;}
/* NOVO */
.category-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(180px,1fr));
  gap:12px;
}

.category-card{
  background:var(--card);
  border:none;
  border-radius:18px;
  padding:20px 18px 16px;
  display:flex;
  flex-direction:column;
  align-items:flex-start;
  gap:0;
  box-shadow:0 2px 12px rgba(0,0,0,.06);
  transition:transform .2s, box-shadow .2s;
  overflow:hidden;
  position:relative;
  cursor:default;
}
.category-card:hover{
  transform:translateY(-3px);
  box-shadow:0 8px 24px rgba(0,0,0,.11);
}

/* Bolinha decorativa no fundo */
.category-card::after{
  content:'';
  position:absolute;
  right:-14px;bottom:-14px;
  width:60px;height:60px;
  border-radius:50%;
  background:var(--primary);
  opacity:.05;
  pointer-events:none;
}

/* Ícone com fundo colorido */
.category-emoji-wrap{
  width:46px;height:46px;
  border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  font-size:22px;
  margin-bottom:12px;
  flex-shrink:0;
}

.category-name{
  font-size:13px;
  font-weight:800;
  color:var(--text);
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
  max-width:100%;
  letter-spacing:-.1px;
  margin-bottom:2px;
}
.category-label{
  font-size:10px;
  color:var(--muted);
  font-weight:600;
  text-transform:uppercase;
  letter-spacing:.04em;
  margin-bottom:10px;
}
.category-actions{
  display:flex;
  gap:4px;
  margin-top:auto;
  padding-top:10px;
  width:100%;
