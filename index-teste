        </div>
      </div>
      <button class="btn btn-success btn-block" style="margin-top:14px;font-size:13px" onclick="payDebtInstallment('${d.id}')">
        💸 Pagar Parcela — ${fmtBRL(d.installment)}
      </button>
    `;
    list.appendChild(card);
  });
}

function renderDashDebts() {
  const card = document.getElementById('dash-debts-card');
  const content = document.getElementById('dash-debts-content');
  if (!card || !content) return;

  // Esconde se não tiver dívidas
  if (!state.debts || !state.debts.length) {
    card.style.display = 'none';
    return;
  }

  card.style.display = '';
  const totalAll   = state.debts.reduce((s, d) => s + d.total, 0);
  const paidAll    = state.debts.reduce((s, d) => s + d.paid, 0);
  const restAll    = totalAll - paidAll;
  const pctAll     = totalAll > 0 ? Math.round((paidAll / totalAll) * 100) : 0;
  const monthlyAll = state.debts.reduce((s, d) => s + d.installment, 0);

  content.innerHTML = `
    <div class="debt-summary-grid" style="margin-bottom:14px">
      <div class="debt-summary-item">
        <div class="debt-summary-label">Total em Dívidas</div>
        <div class="debt-summary-value" style="font-size:15px;color:var(--danger)">${fmtBRL(totalAll)}</div>
      </div>
      <div class="debt-summary-item">
        <div class="debt-summary-label">Total Pago</div>
        <div class="debt-summary-value" style="font-size:15px;color:var(--success)">${fmtBRL(paidAll)}</div>
      </div>
      <div class="debt-summary-item">
        <div class="debt-summary-label">Restante</div>
        <div class="debt-summary-value" style="font-size:15px;color:var(--danger)">${fmtBRL(restAll)}</div>
      </div>
      <div class="debt-summary-item">
        <div class="debt-summary-label">Parcelas/Mês</div>
        <div class="debt-summary-value" style="font-size:15px;color:var(--primary)">${fmtBRL(monthlyAll)}</div>
      </div>
    </div>
    <div class="debt-progress-label">
      <span>Progresso geral das dívidas</span>
      <span style="color:var(--primary);font-weight:800">${pctAll}% pago</span>
    </div>
    <div class="debt-progress-bar">
      <div class="debt-progress-fill" style="width:${pctAll}%"></div>
    </div>
  `;
}

</script>

</body>
</html>
