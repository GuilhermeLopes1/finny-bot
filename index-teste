async function doChangePassword(){
  const current  = document.getElementById('cp-current').value;
  const newPass  = document.getElementById('cp-new').value;
  const confirm  = document.getElementById('cp-confirm').value;
  const errEl    = document.getElementById('cp-error');
  const okEl     = document.getElementById('cp-success');
  errEl.style.display = 'none';
  okEl.style.display  = 'none';

  if(!current || !newPass || !confirm){ showAuthErr(errEl,'Preencha todos os campos.'); return; }
  if(newPass.length < 6){ showAuthErr(errEl,'Nova senha deve ter ao menos 6 caracteres.'); return; }
  if(newPass !== confirm){ showAuthErr(errEl,'As senhas não coincidem.'); return; }

  try {
    const user       = auth.currentUser;
    const credential = firebase.auth.EmailAuthProvider.credential(user.email, current);
    await user.reauthenticateWithCredential(credential);
    await user.updatePassword(newPass);
    okEl.textContent     = '✅ Senha alterada com sucesso!';
    okEl.style.display   = 'block';
    document.getElementById('cp-current').value = '';
    document.getElementById('cp-new').value     = '';
    document.getElementById('cp-confirm').value = '';
    setTimeout(()=> closeModal('modal-change-password'), 2000);
  } catch(e){
    const msgs = {
      'auth/wrong-password'        : 'Senha atual incorreta.',
      'auth/requires-recent-login' : 'Sessão expirada. Faça login novamente.',
      'auth/weak-password'         : 'Nova senha muito fraca.',
    };
    showAuthErr(errEl, msgs[e.code] || 'Erro ao alterar senha.');
  }
}

