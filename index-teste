async function payDebtInstallment(id) {
  const d = state.debts.find(x => x.id === id);
  if (!d) return;

  const rest = d.total - d.paid;
  if (rest <= 0) { toast('✅ Esta dívida já está quitada!'); return; }

  const valor = parseFloat(prompt(
    `💸 Pagar parcela de "${d.name}"\n\nValor sugerido: R$ ${d.installment.toFixed(2).replace('.',',')}\n\nDigite o valor pago (ou Enter para confirmar):`,
    d.installment.toFixed(2)
  ));
  if (!valor || valor <= 0) return;

  // Atualiza a dívida
  const idx = state.debts.findIndex(x => x.id === id);
  state.debts[idx].paid = Math.min(state.debts[idx].paid + valor, state.debts[idx].total);

  // Cria transação de despesa automaticamente
  const today = new Date().toISOString().split('T')[0];
  state.transactions.push({
    id: 'tx_debt_' + Date.now(),
    type: 'expense',
    amount: valor,
    description: `Parcela: ${d.name}`,
    category: 'Dívidas',
    date: today,
    status: 'paid',
    createdAt: new Date().toISOString()
  });

  await save();
  renderDebts();
  if (state.currentPage === 'dashboard') renderDashboard();
  toast(`✅ Parcela de ${fmtBRL(valor)} registrada para "${d.name}"!`);
}

