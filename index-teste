async function saveBotPhone(){
  const input = document.getElementById("bot-phone-input");
  let phone = input.value.trim().replace(/\D/g,'');
  if(!phone || phone.length < 10){
    toast('Informe um número válido com DDI. Ex: 5511999999999');
    return;
  }
  if(!phone.startsWith('55')) phone = '55' + phone;
  try {
    await db.collection("users").doc(state.user.uid)
      .set({ phoneNumber: phone }, { merge: true });
    toast('✅ Número cadastrado com sucesso!');
    renderBotPage(); // atualiza badge
  } catch(e){
    toast('Erro ao salvar número.');
  }
}

