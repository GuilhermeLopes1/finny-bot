function renderTrends(){
  const el=document.getElementById('trends-content'); if(!el)return;
  const now=new Date();
  // Collect data for last 3 months
  const monthlyData=[];
  for(let i=1;i<=3;i++){
    const d=new Date(now.getFullYear(),now.getMonth()-i,1);
    let inc=0,exp=0;
    state.transactions.forEach(t=>{
      const td=new Date(t.date+'T12:00:00');
      if(td.getMonth()===d.getMonth()&&td.getFullYear()===d.getFullYear()){
        if(t.type==='income')inc+=t.amount;else exp+=t.amount;
      }
    });
    monthlyData.push({inc,exp,bal:inc-exp});
  }
  const hasData=monthlyData.some(m=>m.inc>0||m.exp>0);
  if(!hasData){
    el.innerHTML='<div class="empty-state" style="padding:16px"><div class="emoji" style="font-size:30px">📊</div><p style="font-size:13px">Adicione transações para ver as previsões</p></div>';
    return;
  }
  const avgInc=monthlyData.reduce((a,m)=>a+m.inc,0)/3;
  const avgExp=monthlyData.reduce((a,m)=>a+m.exp,0)/3;
  const avgBal=avgInc-avgExp;
  // Trend direction
  const incTrend=monthlyData[0].inc>monthlyData[2].inc?'crescendo':'caindo';
  const expTrend=monthlyData[0].exp>monthlyData[2].exp?'aumentando':'diminuindo';
  const balSign=avgBal>=0?'+':'';

  el.innerHTML=`
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;margin-bottom:14px">
      <div class="trend-card">
        <div class="trend-label">📈 Receita Estimada (próx. mês)</div>
        <div class="trend-value">${fmtBRL(avgInc)}</div>
        <div class="trend-sub">Receitas ${incTrend} nos últimos 3 meses</div>
      </div>
      <div class="trend-card" style="background:linear-gradient(135deg,#ef4444,#f59e0b)">
        <div class="trend-label">📉 Despesa Estimada (próx. mês)</div>
        <div class="trend-value">${fmtBRL(avgExp)}</div>
        <div class="trend-sub">Gastos ${expTrend} nos últimos 3 meses</div>
      </div>
      <div class="trend-card" style="background:linear-gradient(135deg,${avgBal>=0?'#22c55e,#16a34a':'#ef4444,#dc2626'})">
        <div class="trend-label">💰 Saldo Projetado</div>
        <div class="trend-value">${balSign}${fmtBRL(avgBal)}</div>
        <div class="trend-sub">${avgBal>=0?'Você deve economizar este mês!':'Atenção: gastos superam receitas'}</div>
      </div>
    </div>
    <div style="background:var(--bg);border-radius:10px;padding:12px 14px;font-size:13px;color:var(--muted);">
      💡 <strong style="color:var(--text)">Previsão IA:</strong>
      Você deve gastar aproximadamente <strong style="color:var(--danger)">${fmtBRL(avgExp)}</strong> no próximo mês.
      ${avgBal>=0?`Seu saldo deve ser positivo em <strong style="color:var(--success)">${fmtBRL(avgBal)}</strong>.`:`Seu saldo pode ficar negativo em <strong style="color:var(--danger)">${fmtBRL(Math.abs(avgBal))}</strong>.`}
    </div>`;
}

