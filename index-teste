function renderTransactions(){
  const wrap  = document.getElementById('tx-feed-wrap');
  const empty = document.getElementById('transactions-empty');

  // Atualiza contador de categorias (vem daqui por compatibilidade)
  const countCat = document.getElementById('cat-count-label');
  if(countCat) countCat.textContent = `${state.categories.length} categoria${state.categories.length!==1?'s':''} cadastrada${state.categories.length!==1?'s':''}`;

  let sorted = [...state.transactions].sort((a,b)=>b.date.localeCompare(a.date));

  // Aplicar filtro
  if(txFilter === 'income')  sorted = sorted.filter(t=>t.type==='income');
  if(txFilter === 'expense') sorted = sorted.filter(t=>t.type==='expense');
  if(txFilter === 'pending') sorted = sorted.filter(t=>(t.status||'paid')==='pending');

  // Atualiza label do header
  const countEl = document.getElementById('tx-count-label');
  if(countEl) countEl.textContent = `${sorted.length} transaç${sorted.length!==1?'ões':'ão'} encontrada${sorted.length!==1?'s':''}`;

  if(!sorted.length){
    wrap.innerHTML='';
    empty.classList.remove('hidden');
    return;
  }
  empty.classList.add('hidden');

  // Agrupar por data
  const groups = {};
  sorted.forEach(t=>{
    const d = t.date || '';
    if(!groups[d]) groups[d]=[];
    groups[d].push(t);
  });

  const today    = new Date().toISOString().split('T')[0];
  const yesterday= new Date(Date.now()-86400000).toISOString().split('T')[0];

  const CAT_BG_COLORS_TX   = ['#EDE9FF','#DCFCE7','#FEE2E2','#FEF3C7','#DBEAFE','#FCE7F3','#F0FDF4','#FFF7ED','#EFF6FF','#F5F3FF'];
  const CAT_ICON_COLORS_TX = ['#6C63FF','#22c55e','#ef4444','#f59e0b','#3b82f6','#ec4899','#16a34a','#ea580c','#2563eb','#7c3aed'];

  let html = '';
  Object.keys(groups).sort((a,b)=>b.localeCompare(a)).forEach(date=>{
    const label = date===today ? 'Hoje' : date===yesterday ? 'Ontem' : fmtDate(date);
    html += `<div class="tx-group-label">${label}</div><div class="tx-feed">`;

    groups[date].forEach(t=>{
      const cat   = state.categories.find(c=>c.id===t.category)||{emoji:'📋',name:'—'};
      const bank  = t.bankId ? state.banks.find(b=>b.id===t.bankId) : null;
      const card  = t.cardId ? state.cards.find(c=>c.id===t.cardId) : null;
      const acct  = card ? `${CARD_BRAND_EMOJIS[card.brand]||'💳'} ${escHtml(card.name)}`
                  : bank ? `🏦 ${escHtml(bank.name)}` : '';
      const isPaid   = (t.status||'paid')==='paid';
      const catIdx   = state.categories.findIndex(c=>c.id===t.category);
      const bgColor  = CAT_BG_COLORS_TX[catIdx>=0 ? catIdx%CAT_BG_COLORS_TX.length : 0];
      const iconColor= CAT_ICON_COLORS_TX[catIdx>=0 ? catIdx%CAT_ICON_COLORS_TX.length : 0];

      html += `
      <div class="tx-row" style="opacity:${isPaid?1:.65}">
        <div class="tx-icon" style="background:${bgColor};color:${iconColor}">${cat.emoji}</div>
        <div class="tx-info">
          <div class="tx-desc">${escHtml(t.description||'—')}</div>
          <div class="tx-meta">
            <span>${escHtml(cat.name)}</span>
            ${acct?`<span>·</span><span>${acct}</span>`:''}
            <span>·</span>
            <span style="cursor:pointer" onclick="toggleTxStatus('${t.id}')">
              ${isPaid?'✅ Pago':'⏳ Pendente'}
            </span>
          </div>
        </div>
        <div class="tx-right">
          <span class="tx-amount ${t.type==='income'?'pos':'neg'}">
            ${t.type==='income'?'+':'-'}${fmtBRL(t.amount)}
          </span>
          <div class="tx-actions">
            <button class="icon-btn" title="Editar" onclick="abrirEdicao('${t.id}','${escHtml(t.description||t.desc||'')}',${t.amount},'${escHtml(t.category||'')}','${t.type}')">✏️</button>
            <button class="icon-btn" title="Excluir" onclick="deleteTransaction('${t.id}')">🗑️</button>
          </div>
        </div>
      </div>`;
    });

    html += `</div>`;
  });

  wrap.innerHTML = html;
}
