function getReportData(period){
  const now=new Date();
  const labels=[],incData=[],expData=[];
  if(period==='daily'){
    for(let i=6;i>=0;i--){
      const d=new Date(now.getFullYear(),now.getMonth(),now.getDate()-i);
      const iso=d.toISOString().split('T')[0];
      labels.push(d.toLocaleDateString('pt-BR',{weekday:'short',day:'2-digit'}));
      let inc=0,exp=0;
      state.transactions.forEach(t=>{if(t.date===iso){if(t.type==='income')inc+=t.amount;else exp+=t.amount;}});
      incData.push(inc);expData.push(exp);
    }
  } else if(period==='weekly'){
    for(let i=7;i>=0;i--){
      const wEnd=new Date(now.getFullYear(),now.getMonth(),now.getDate()-i*7);
      const wStart=new Date(wEnd.getFullYear(),wEnd.getMonth(),wEnd.getDate()-6);
      labels.push(wStart.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'}));
      let inc=0,exp=0;
      state.transactions.forEach(t=>{
        const td=new Date(t.date+'T12:00:00');
        if(td>=wStart&&td<=wEnd){if(t.type==='income')inc+=t.amount;else exp+=t.amount;}
      });
      incData.push(inc);expData.push(exp);
    }
  } else if(period==='monthly'){
    const months=['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
    for(let i=11;i>=0;i--){
      const d=new Date(now.getFullYear(),now.getMonth()-i,1);
      labels.push(months[d.getMonth()]+' '+String(d.getFullYear()).slice(2));
      let inc=0,exp=0;
      state.transactions.forEach(t=>{
        const td=new Date(t.date+'T12:00:00');
        if(td.getMonth()===d.getMonth()&&td.getFullYear()===d.getFullYear()){if(t.type==='income')inc+=t.amount;else exp+=t.amount;}
      });
      incData.push(inc);expData.push(exp);
    }
  } else if(period==='yearly'){
    for(let i=4;i>=0;i--){
      const year=now.getFullYear()-i;
      labels.push(String(year));
      let inc=0,exp=0;
      state.transactions.forEach(t=>{
        if(new Date(t.date+'T12:00:00').getFullYear()===year){if(t.type==='income')inc+=t.amount;else exp+=t.amount;}
      });
      incData.push(inc);expData.push(exp);
    }
  }
  return{labels,incData,expData};
}

