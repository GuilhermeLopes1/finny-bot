function openEditBank(id){
  const b = state.banks.find(x => x.id === id);
  if(!b) return;

  state.editId = id;

  document.getElementById('modal-bank-title').textContent = 'Editar Conta';

  const sel = document.getElementById('bank-name-select');
  const known = ['Nubank','Itaú','Bradesco','Banco do Brasil','Caixa','Santander','Inter','C6 Bank'];

  if(known.includes(b.name)){
    sel.value = b.name;
  } else {
    sel.value = 'Outro';
    document.getElementById('bank-name-custom').value = b.name;
    document.getElementById('bank-name-custom-group').classList.remove('hidden');
  }

  document.getElementById('bank-type').value = b.type || 'corrente';
  document.getElementById('bank-balance').value = b.balance || 0;

  openModal('modal-bank');
}


function saveBank(){
  const sel = document.getElementById('bank-name-select').value;
  const name = sel === 'Outro'
    ? document.getElementById('bank-name-custom').value.trim()
    : sel;

  const type = document.getElementById('bank-type').value;
  const balance = parseFloat(document.getElementById('bank-balance').value) || 0;

  if(!name){
    toast('Selecione ou informe o banco.');
    return;
  }

  if(state.editId){
    const idx = state.banks.findIndex(b => b.id === state.editId);
    if(idx >= 0){
      state.banks[idx] = {
        ...state.banks[idx],
        name,
        type,
        balance
      };
    }
  } else {
    state.banks.push({
      id: uid(),
      name,
      type,
      balance
    });
  }

  save();
  closeModal('modal-bank');
  renderBanks();

  toast(state.editId ? 'Conta atualizada!' : 'Conta criada! 🏦');
}


function deleteBank(id){
  const bank = state.banks.find(b => b.id === id);
  if(!bank) return;

  if(!confirm(`Excluir a conta "${bank.name}"?`)) return;

  state.banks = state.banks.filter(b => b.id !== id);

  save();
  renderBanks();

  toast('Conta excluída 🗑️');
}
