// Smart AI categorization using keyword mapping
function smartCategorize(desc){
  const lower=(desc||'').toLowerCase();
  for(const mapping of KEYWORD_MAP){
    if(mapping.kws.some(kw=>lower.includes(kw))){
      const cat=state.categories.find(c=>c.name===mapping.cat);
      if(cat)return cat.id;
    }
  }
  // Fallback to first non-income category
  const fallback=state.categories.find(c=>c.name!=='Salário'&&c.name!=='Investimentos');
  return fallback?fallback.id:(state.categories[0]?.id||'');
}

